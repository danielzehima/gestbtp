FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production-please
JWT_SECRET_KEY=change-me-jwt-secret-too

# Supabase Postgres (mode Transaction pooler, port 6543 — obligatoire pour Vercel)
# Récupère cette URL dans : Supabase → Settings → Database → Connection string → URI → Transaction
# ⚠ Si ton mot de passe contient des caractères spéciaux (@, #, !, $...), URL-encode-les :
#    @ → %40    # → %23    ! → %21    $ → %24
DATABASE_URL=postgresql://postgres.xxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# Optionnel — Storage Supabase pour les photos
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-public-key-here

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=GESTBTP <no-reply@gestbtp.com>

UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216
